# Team-shared .gitignore for this iOS/Xcode repository.
# Keep source code and project configuration tracked; ignore generated/local-only artifacts.

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Xcode user/workspace settings
xcuserdata/
*.xcscmblueprint
*.xccheckout
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# Build outputs and packaging
build/
DerivedData/
.build/
*.moved-aside
*.hmap
*.ipa
*.dSYM
*.dSYM.zip

# Xcode test/report artifacts
*.xcresult
*.xccovreport
*.xccovarchive
*.xcactivitylog

# Swift playground
timeline.xctimeline
playground.xcworkspace

# Dependency manager generated artifacts
Carthage/Build/
Dependencies/
.accio/

# fastlane generated outputs
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Code injection tools
iOSInjectionProject/

# IDE/editor local settings
buildServer.json
.vscode/
.idea/
*.mdc

# Temp, logs, and diagnostics
*.tmp
*.temp
*~
*.bak
*.backup
*.log
*.trace
*.profraw
*.profdata
*.crash
logs/
Logs/

# Local AI tooling files
.claude/
CLAUDE.md

# Project-local artifacts (agreed to keep out of git)
doc/
build-check/
build-device/
.pkgcache/
